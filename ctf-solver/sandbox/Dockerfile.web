FROM ctf-base:latest

RUN apt-get update && apt-get install -y \
    sqlmap \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    flask \
    PyJWT \
    beautifulsoup4 \
    lxml

# ffuf
RUN curl -sL https://github.com/ffuf/ffuf/releases/latest/download/ffuf_$(curl -s https://api.github.com/repos/ffuf/ffuf/releases/latest | grep -oP '"tag_name":\s*"v\K[^"]+')_linux_amd64.tar.gz \
    | tar xz -C /usr/local/bin ffuf || true

# dalfox
RUN curl -sL https://github.com/hahwul/dalfox/releases/latest/download/dalfox_$(curl -s https://api.github.com/repos/hahwul/dalfox/releases/latest | grep -oP '"tag_name":\s*"v\K[^"]+')_linux_amd64.tar.gz \
    | tar xz -C /usr/local/bin dalfox || true

# podman (for running challenge Docker images)
RUN apt-get update && apt-get install -y podman buildah fuse-overlayfs slirp4netns 2>/dev/null \
    && rm -rf /var/lib/apt/lists/* || true

# Playwright
RUN pip3 install --no-cache-dir playwright \
    && playwright install chromium --with-deps || true
